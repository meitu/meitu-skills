{
  "generated": true,
  "aggregated_skill": "meitu-tools",
  "capabilities": [
    "video-motion-transfer",
    "image-to-video",
    "text-to-video",
    "video-to-gif",
    "image-generate",
    "image-poster-generate",
    "image-edit",
    "image-upscale",
    "image-beauty-enhance",
    "image-face-swap",
    "image-try-on",
    "image-adapt",
    "image-cutout",
    "image-grid-split"
  ],
  "credentials": {
    "required": [
      "MEITU_OPENAPI_ACCESS_KEY",
      "MEITU_OPENAPI_SECRET_KEY"
    ],
    "sources": [
      "environment",
      "~/.meitu/credentials.json"
    ]
  },
  "runtime": {
    "bins": [
      "meitu",
      "node"
    ],
    "install": "npm install -g meitu-cli@latest"
  }
}
